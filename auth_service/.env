# === Приложение ===
APP_NAME=auth-service
ENV=local

# === JWT (ОБЯЗАТЕЛЬНО замените в продакшене!) ===
JWT_SECRET=change_me_super_secret
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === База данных ===
SQLITE_PATH=./auth.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/authdb